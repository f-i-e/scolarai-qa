# Origin only (scheme + host). Do NOT append /api or /api/v1 here.
SCHOLARAI_API_BASE_URL=https://test-api.scolarai.com

# If POST …/auth/register returns HTTP 500, that is a backend issue (email, DB, secrets), not a bad test URL.

# Synthetic register emails: {prefix}+{timestamp}.{rand}@<domain> — change if your API allowlists domains
# SCHOLARAI_TEST_EMAIL_DOMAIN=qa.scolarai.test

# Prefix before /auth/... Default /api/v1 (OpenAPI). Use /api only if your gateway has no version segment.
# In GitHub Actions, leave this variable **unset** (do not create an empty repo var) or set explicitly to /api or /api/v1.
# SCHOLARAI_API_VERSION_PREFIX=/api

# Optional: override full path for a single route
# SCHOLARAI_PATH_REGISTER=/api/auth/register

# Verified account (TC07–TC08, TC12–TC14, TC22–TC24)
SCHOLARAI_VERIFIED_USER_EMAIL=
SCHOLARAI_VERIFIED_USER_PASSWORD=

# TC05 — POST …/auth/verify body { "otp_code": number }
SCHOLARAI_VALID_OTP_CODE=

# TC11 — expired access JWT (default protected URL: GET …/api/v1/auth/me)
SCHOLARAI_EXPIRED_ACCESS_TOKEN=
SCHOLARAI_PROTECTED_SMOKE_URL=

# TC17–TC20 — paths from site root, e.g. /api/tutor/classes (or full https URL)
SCHOLARAI_URL_TUTOR_ONLY=
SCHOLARAI_URL_STUDENT_ONLY=
SCHOLARAI_URL_PARENT_ONLY=
SCHOLARAI_URL_ADMIN_ONLY=
SCHOLARAI_PARENT_ACCESS_TOKEN=

SCHOLARAI_RUN_RATE_LIMIT=0
SCHOLARAI_ALLOW_OFFLINE=0
